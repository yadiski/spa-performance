# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/spa

# Better Auth
BETTER_AUTH_SECRET=change-me-32-chars-minimum
BETTER_AUTH_URL=http://localhost:3000

# Resend (phase 2)
RESEND_API_KEY=
# RESEND_FROM_EMAIL=no-reply@example.com

# Cloudflare R2 (phase 2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# OpenRouter (phase 3)
OPENROUTER_API_KEY=

# Runtime
NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:5173

# Phase 4 — CORS tightening (T14)
# Comma-separated list of additional allowed CORS origins (e.g. staging).
# In production set WEB_ORIGIN to the production front-end URL.
# ADDITIONAL_CORS_ORIGINS=https://staging.example.com,https://preview.example.com
