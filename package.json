{
  "name": "spa-performance",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "build": "bun run --filter './apps/*' build",
    "test": "bun test",
    "typecheck": "bun run --filter './apps/*' typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.3.12",
    "lefthook": "^2.1.6",
    "typescript": "^5.6.3"
  }
}
